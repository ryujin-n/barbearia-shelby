<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutRaizNovoAgend"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E2A3A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/btnVoltar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/outline_arrow_back_ios_24"
                app:tint="#FFFFFF"
                android:layout_marginEnd="12dp"
                android:padding="4dp"
                android:contentDescription="@string/voltar"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/novo_agendamento"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/servico"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupServico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            android:layout_marginBottom="24dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCorte"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/corte"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="@color/chip_color"
                app:chipSurfaceColor="@android:color/transparent"
                app:chipStrokeColor="#E53935"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBarba"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/barba"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="@color/chip_color"
                app:chipSurfaceColor="@android:color/transparent"
                app:chipStrokeColor="#E53935"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCorteBarba"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/corte_barba"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="@color/chip_color"
                app:chipSurfaceColor="@android:color/transparent"
                app:chipStrokeColor="#E53935"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDegrade"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/degrade"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="@color/chip_color"
                app:chipSurfaceColor="@android:color/transparent"
                app:chipStrokeColor="#E53935"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSobrancelha"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sobrancelha"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="@color/chip_color"
                app:chipSurfaceColor="@android:color/transparent"
                app:chipStrokeColor="#E53935"
                app:chipStrokeWidth="1dp"/>

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/barbeiro"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutBarbeiro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/selecione_o_barbeiro"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxStrokeColor="@color/box_stroke_selector"
            app:hintTextColor="@color/black"
            app:endIconTint="@color/alizarin"
            app:boxBackgroundColor="@android:color/transparent"
            android:textColorHint="@color/alizarin"
            android:layout_marginBottom="24dp">

            <AutoCompleteTextView
                android:id="@+id/dropdownBarbeiro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#FFFFFF"
                android:background="@null" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/data"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/selecione_a_data"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/box_stroke_selector"
            app:hintTextColor="@color/alizarin"
            app:cursorColor="@color/alizarin"
            android:textColorHint="@color/alizarin"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_calendario"
            app:endIconTint="#90CAF9"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"/>

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/horario"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/selecione_o_horario"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/box_stroke_selector"
            app:hintTextColor="@color/alizarin"
            app:cursorColor="@color/alizarin"
            android:textColorHint="@color/alizarin"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_relogio"
            app:endIconTint="#90CAF9"
            android:layout_marginBottom="32dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editHorario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"/>

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnConfirmarAgendamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirmar_agendamento"
            android:backgroundTint="#E53935"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="14dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>